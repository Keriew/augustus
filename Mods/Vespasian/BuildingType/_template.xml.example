<?xml version="1.0" encoding="utf-8"?>
<building type="replace_with_building_attr">
    <!-- Optional runtime state definition -->
    <state>
        <water_access mode="reservoir_range" />
    </state>

    <!-- Optional graphics definition -->
    <graphics>
        <default>
            <path value="Health_Culture\Example_Base" />
        </default>
        <variant>
            <condition type="desirability" operator="gt" threshold="50" />
            <condition type="working" />
            <path value="Health_Culture\Example_Fancy_Working" />
        </variant>
        <variant>
            <condition type="working" />
            <path value="Health_Culture\Example_Working" />
        </variant>
        <overlay>
            <condition type="water_access" />
            <path value="Aesthetics\Example_Overlay" />
            <image value="Overlay_Anim" />
        </overlay>
    </graphics>

    <!-- Optional labor phase -->
    <labor labor_seeker_mode="spawn_if_below" labor_min_houses="50" />

    <!-- Optional shared-delay spawn group -->
    <spawn_group road_access="normal" delay_bands="100:3,75:7,50:15,25:29,1:44" existing_figure="librarian"
        guard_timing="before_road_access">
        <spawn mode="service_roamer" spawn_figure="librarian"
            action_state="roaming" direction="top" figure_slot="primary" spawn_count="1" init_roaming="true"
            graphic_timing="before_delay_check" require_water_access="false" mark_problem_if_no_water="false"
            condition="always" block_on_success="true" />
    </spawn_group>
</building>
