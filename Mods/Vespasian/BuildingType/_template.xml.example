<?xml version="1.0" encoding="utf-8"?>
<building type="replace_with_building_attr">
    <!-- Optional provider-side water access definition -->
    <water_access>
        <type value="reservoir" />
        <range value="10" />
        <requirement value="water_source_any" />
        <node kind="aqueduct_connection" x="1" y="-1" />
        <node kind="aqueduct_connection" x="3" y="1" />
        <node kind="aqueduct_connection" x="1" y="3" />
        <node kind="aqueduct_connection" x="-1" y="1" />
    </water_access>

    <!-- Optional runtime state definition -->
    <state>
        <water_access mode="reservoir_range" />
    </state>

    <!-- Optional graphics definition -->
    <graphics>
        <default>
            <path value="Health_Culture\Example_Base" />
            <image value="Image_0000" />
        </default>
        <variant>
            <condition type="desirability" operator="gt" threshold="50" />
            <condition type="has_workers" />
            <condition type="water_access" />
            <path value="Health_Culture\Example_Fancy_Working" />
        </variant>
        <variant>
            <condition type="has_workers" />
            <condition type="water_access" />
            <path value="Health_Culture\Example_Working" />
        </variant>
        <variant>
            <condition type="figure_slot_occupied" slot="quaternary" />
            <path value="Health_Culture\Example_Guarded" />
        </variant>
        <variant>
            <condition type="resource_positive" resource="wine" />
            <path value="Health_Culture\Example_Supplied" />
        </variant>
    </graphics>

    <!-- Optional labor phase -->
    <labor>
        <employees count="10" />
        <seeker mode="spawn_if_below" min_houses="50" />
    </labor>

    <!-- Optional native storage/production references -->
    <storages>
        <storage path="example_storage" />
    </storages>
    <production_methods>
        <production_method path="example_production_method" />
    </production_methods>

    <!-- Optional shared-delay spawn group -->
    <spawn_group road_access="normal" delay_bands="100:3,75:7,50:15,25:29,1:44" existing_figure="librarian"
        guard_timing="before_road_access">
        <spawn mode="service_roamer" spawn_figure="librarian"
            action_state="roaming" direction="top" figure_slot="primary" spawn_count="1" init_roaming="true"
            graphic_timing="before_delay_check" require_water_access="false" mark_problem_if_no_water="false"
            condition="always" block_on_success="true" />
    </spawn_group>

    <!-- Graphics-only vertical slices may stop after <graphics> or <labor> when live runtime ownership is deferred -->
</building>
